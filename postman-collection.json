                  "const body = pm.response.json();",
                  "pm.test('statusPagamento é CANCELADO', () => pm.expect(body.statusPagamento).to.eql('CANCELADO'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
