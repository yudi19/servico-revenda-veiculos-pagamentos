              "code": 400,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"timestamp\": \"2026-03-14T15:00:00\",\n  \"status\": 400,\n  \"erro\": \"Bad Request\",\n  \"mensagem\": \"veiculoId: veiculoId é obrigatório, cpfComprador: cpfComprador é obrigatório, dataVenda: dataVenda é obrigatória\"\n}"
