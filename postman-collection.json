            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"codigoPagamento\": \"{{codigoPagamento}}\",\n  \"status\": \"CANCELADO\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/vendas/webhook",
              "host": ["{{baseUrl}}"],
              "path": ["vendas", "webhook"]
            },
            "description": "Webhook para cancelamento do pagamento.\n\nAo receber CANCELADO:\n- statusPagamento da venda → CANCELADO\n- status do veículo no serviço de listagem → DISPONIVEL (veículo volta ao estoque)"
          },
          "response": [
