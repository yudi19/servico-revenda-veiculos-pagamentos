        {
          "name": "Listar Veículos Vendidos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Retorna array', () => pm.expect(body).to.be.an('array'));",
                  "if (body.length > 1) {",
                  "    pm.test('Ordenado por preço ASC', () => {",
                  "        for (let i = 0; i < body.length - 1; i++) {",
                  "            pm.expect(body[i].precoVeiculo).to.be.at.most(body[i+1].precoVeiculo);",
                  "        }",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/vendas/vendidos",
              "host": ["{{baseUrl}}"],
              "path": ["vendas", "vendidos"]
            },
            "description": "Lista todos os veículos vendidos (pagamento APROVADO), ordenados por preço do mais barato para o mais caro."
          },
          "response": [
            {
